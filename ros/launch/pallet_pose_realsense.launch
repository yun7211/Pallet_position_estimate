<launch>
  <arg name="config_path" default="$(find pallet_pose_estimation)/config/ros1_noetic.yaml" />
  <arg name="yolo_model_path" default="" />
  <arg name="template_point_cloud_path" default="" />
  <arg name="base_frame" default="base_link" />
  <arg name="camera_frame" default="camera_color_optical_frame" />
  <arg name="color_topic" default="/camera/color/image_raw" />
  <arg name="depth_topic" default="/camera/aligned_depth_to_color/image_raw" />
  <arg name="camera_info_topic" default="/camera/color/camera_info" />
  <arg name="align_depth" default="true" />
  <arg name="target_label" default="" />
  <arg name="fallback_strategy" default="error" />
  <arg name="enable_ocr" default="true" />

  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="enable_color" value="true" />
    <arg name="enable_depth" value="true" />
    <arg name="align_depth" value="$(arg align_depth)" />
  </include>

  <node pkg="pallet_pose_estimation" type="run_ros1_node.py" name="pallet_pose_ros1_node" output="screen">
    <param name="config_path" value="$(arg config_path)" />
    <param name="yolo_model_path" value="$(arg yolo_model_path)" />
    <param name="template_point_cloud_path" value="$(arg template_point_cloud_path)" />
    <param name="base_frame" value="$(arg base_frame)" />
    <param name="camera_frame" value="$(arg camera_frame)" />
    <param name="color_topic" value="$(arg color_topic)" />
    <param name="depth_topic" value="$(arg depth_topic)" />
    <param name="camera_info_topic" value="$(arg camera_info_topic)" />
    <param name="target_label" value="$(arg target_label)" />
    <param name="fallback_strategy" value="$(arg fallback_strategy)" />
    <param name="enable_ocr" value="$(arg enable_ocr)" />
  </node>
</launch>
